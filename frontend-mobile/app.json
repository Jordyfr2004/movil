{
  "expo": {
    "name": "Comedor ULEAM",
    "slug": "comedor-uleam",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.comedoruleam"
    },
    "web": {
      "output": "single"
    },
    "experiments": {
      "reactCompiler": true
    },
    "plugins": [
      "expo-secure-store"
    ]
  }
}
